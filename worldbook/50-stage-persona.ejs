<%_
/* 清瞳好感人设控制器 v3.4.0 */
var stat = (typeof getvar === 'function' ? getvar('stat_data') : (variables.stat_data || variables)) || {};
var affinity = _.clamp(Number(_.get(stat, '清瞳.好感度', 5)) || 0, 0, 100);
var affinityProfiles = [
  { min: 0, max: 19, label: '疏离 / 警戒', entry: '[mvu_plot]清瞳好感人设槽位·00-19' },
  { min: 20, max: 39, label: '试探 / 有限合作', entry: '[mvu_plot]清瞳好感人设槽位·20-39' },
  { min: 40, max: 59, label: '信任 / 同伴', entry: '[mvu_plot]清瞳好感人设槽位·40-59' },
  { min: 60, max: 79, label: '亲近 / 牵挂', entry: '[mvu_plot]清瞳好感人设槽位·60-79' },
  { min: 80, max: 100, label: '深情 / 相守', entry: '[mvu_plot]清瞳好感人设槽位·80-100' },
];
var affinityProfile = affinityProfiles.find((profile) => affinity >= profile.min && affinity <= profile.max) || affinityProfiles[0];
var affinityPersonaText = await getwi(charLoreBook || '狐妖小红娘·王权篇·沉浸测试', affinityProfile.entry);
var corePersonaEntry = '[mvu_plot]清瞳核心人设';
var corePersonaText = String(await getwi(charLoreBook || '狐妖小红娘·王权篇·沉浸测试', corePersonaEntry) || '');
var corePersonaReady = corePersonaText.trim() && !corePersonaText.includes('【待作者手动填写】');
_%>
<qing_tong_persona_controller version="3.4.0">
当前好感度：<%- affinity %>/100
当前关系档位：<%- affinityProfile.min %>-<%- affinityProfile.max %> <%- affinityProfile.label %>
<%_ if (corePersonaReady) { _%>
<qing_tong_core_persona>
<%- corePersonaText.trim() %>
</qing_tong_core_persona>
<%_ } _%>
<qing_tong_affinity_persona range="<%- affinityProfile.min %>-<%- affinityProfile.max %>">
<%- affinityPersonaText.trim() %>
</qing_tong_affinity_persona>
说明：核心人设定义清瞳跨阶段稳定的经历、驱动力、行为与信息边界；好感档位只决定她对{{user}}的信任、距离和表达强度，不替换基础人格，也不单独创造恋人关系。正文不得报告数值或档位名称；已经发生的明确互动与选择仍是关系事实的必要依据。
</qing_tong_persona_controller>
